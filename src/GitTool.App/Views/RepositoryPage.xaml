<Page
    x:Class="GitTool.App.Views.RepositoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="Transparent"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid MaxWidth="980" Padding="40,34,40,48" HorizontalAlignment="Center">
            <StackPanel Spacing="24">
                <StackPanel Spacing="8">
                    <TextBlock Style="{StaticResource PageTitleTextStyle}" Text="Manage a repository" />
                    <TextBlock
                        Style="{StaticResource PageSubtitleTextStyle}"
                        Text="Select a local Git working tree, review its current state, then fetch, pull, or push committed changes." />
                </StackPanel>

                <InfoBar
                    x:Name="RepositoryInfoBar"
                    IsClosable="True"
                    IsOpen="False" />

                <Border Style="{StaticResource SectionCardStyle}">
                    <StackPanel Spacing="18">
                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="Local repository" />
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox
                                x:Name="RepositoryPathTextBox"
                                IsReadOnly="True"
                                PlaceholderText="Choose a Git repository folder" />
                            <Button Grid.Column="1" Click="OnChooseRepositoryClick">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon FontSize="16" Glyph="&#xED25;" />
                                    <TextBlock Text="Select repository" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border
                    x:Name="RepositoryDetailsCard"
                    Style="{StaticResource SectionCardStyle}"
                    Visibility="Collapsed">
                    <StackPanel Spacing="22">
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="4">
                                <TextBlock
                                    x:Name="RepositoryNameText"
                                    FontSize="22"
                                    FontWeight="SemiBold" />
                                <TextBlock
                                    x:Name="RepositoryRootText"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                            <Button
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                Click="OnRefreshRepositoryClick">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon FontSize="16" Glyph="&#xE72C;" />
                                    <TextBlock Text="Refresh status" />
                                </StackPanel>
                            </Button>
                        </Grid>

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Padding="14" Background="{ThemeResource SubtleFillColorSecondaryBrush}" CornerRadius="8">
                                <StackPanel Spacing="5">
                                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Branch" />
                                    <TextBlock x:Name="BranchText" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Padding="14" Background="{ThemeResource SubtleFillColorSecondaryBrush}" CornerRadius="8">
                                <StackPanel Spacing="5">
                                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Working tree" />
                                    <TextBlock x:Name="WorkingTreeText" FontWeight="SemiBold" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" Padding="14" Background="{ThemeResource SubtleFillColorSecondaryBrush}" CornerRadius="8">
                                <StackPanel Spacing="5">
                                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Origin" />
                                    <TextBlock x:Name="RemoteText" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <CheckBox
                            x:Name="IncludeSubmodulesCheckBox"
                            Content="Include submodules in fetch and pull operations" />

                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Button Click="OnFetchClick">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon FontSize="16" Glyph="&#xE895;" />
                                    <TextBlock Text="Fetch" />
                                </StackPanel>
                            </Button>
                            <Button Click="OnPullClick" Style="{StaticResource AccentButtonStyle}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon FontSize="16" Glyph="&#xE896;" />
                                    <TextBlock Text="Pull" />
                                </StackPanel>
                            </Button>
                            <Button Click="OnPushClick">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon FontSize="16" Glyph="&#xE898;" />
                                    <TextBlock Text="Push commits" />
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <TextBlock
                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                            Text="Pull uses --ff-only to avoid creating an unexpected merge commit. Add and commit are deliberately isolated as future repository operations."
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
