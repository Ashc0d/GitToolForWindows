<Page
    x:Class="GitTool.App.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="Transparent"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid MaxWidth="900" Padding="40,34,40,48" HorizontalAlignment="Center">
            <StackPanel Spacing="24">
                <StackPanel Spacing="8">
                    <TextBlock Style="{StaticResource PageTitleTextStyle}" Text="Settings" />
                    <TextBlock
                        Style="{StaticResource PageSubtitleTextStyle}"
                        Text="Set shared defaults for cloning, attention notifications, and local diagnostics." />
                </StackPanel>

                <InfoBar
                    x:Name="SettingsInfoBar"
                    IsClosable="True"
                    IsOpen="False" />

                <Border Style="{StaticResource SectionCardStyle}">
                    <StackPanel Spacing="20">
                        <StackPanel Spacing="6">
                            <TextBlock FontSize="18" FontWeight="SemiBold" Text="Cloning" />
                            <TextBlock
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="The default can still be changed on the Clone page." />
                        </StackPanel>

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox
                                x:Name="DefaultCloneDirectoryTextBox"
                                Header="Default clone directory"
                                IsReadOnly="True" />
                            <Button
                                Grid.Column="1"
                                VerticalAlignment="Bottom"
                                Click="OnChooseDefaultDirectoryClick">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon FontSize="16" Glyph="&#xED25;" />
                                    <TextBlock Text="Browse" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionCardStyle}">
                    <StackPanel Spacing="20">
                        <StackPanel Spacing="6">
                            <TextBlock FontSize="18" FontWeight="SemiBold" Text="Attention" />
                            <TextBlock
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="Error dialogs always appear in the app. This setting controls Windows app notifications." />
                        </StackPanel>

                        <ToggleSwitch
                            x:Name="NotificationsToggleSwitch"
                            Header="Windows notifications"
                            OffContent="Silenced"
                            OnContent="Enabled" />

                        <Button HorizontalAlignment="Left" Click="OnTestNotificationClick">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon FontSize="16" Glyph="&#xEA8F;" />
                                <TextBlock Text="Send test notification" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionCardStyle}">
                    <StackPanel Spacing="18">
                        <StackPanel Spacing="6">
                            <TextBlock FontSize="18" FontWeight="SemiBold" Text="Logs and app data" />
                            <TextBlock
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="Logs are buffered in memory, flushed every five minutes, when an error occurs, and when the app closes. Fourteen daily files are retained."
                                TextWrapping="Wrap" />
                        </StackPanel>

                        <TextBox x:Name="LogsDirectoryTextBox" Header="Logs directory" IsReadOnly="True" />

                        <Button HorizontalAlignment="Left" Click="OnOpenLogsClick">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon FontSize="16" Glyph="&#xE838;" />
                                <TextBlock Text="Open logs folder" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <Button
                    HorizontalAlignment="Left"
                    Click="OnSaveSettingsClick"
                    Style="{StaticResource AccentButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon FontSize="16" Glyph="&#xE74E;" />
                        <TextBlock Text="Save settings" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
