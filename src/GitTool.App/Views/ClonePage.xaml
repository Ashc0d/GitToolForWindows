<Page
    x:Class="GitTool.App.Views.ClonePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="Transparent"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid MaxWidth="900" Padding="40,34,40,48" HorizontalAlignment="Center">
            <StackPanel Spacing="24">
                <StackPanel Spacing="8">
                    <TextBlock Style="{StaticResource PageTitleTextStyle}" Text="Clone a repository" />
                    <TextBlock
                        Style="{StaticResource PageSubtitleTextStyle}"
                        Text="GitTool checks your GitHub SSH authentication first. A successful SSH check uses git@github.com; otherwise it safely falls back to HTTPS." />
                </StackPanel>

                <InfoBar
                    x:Name="ResultInfoBar"
                    IsClosable="True"
                    IsOpen="False" />

                <Border Style="{StaticResource SectionCardStyle}">
                    <StackPanel Spacing="22">
                        <StackPanel Spacing="6">
                            <TextBlock FontSize="18" FontWeight="SemiBold" Text="Repository" />
                            <TextBlock
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="Public GitHub HTTPS, SSH, or owner/repository format"
                                TextWrapping="Wrap" />
                        </StackPanel>

                        <TextBox
                            x:Name="RepositoryUrlTextBox"
                            Header="Repository URL"
                            PlaceholderText="https://github.com/owner/repository" />

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox
                                x:Name="DestinationTextBox"
                                Grid.Column="0"
                                Header="Destination folder"
                                IsReadOnly="True"
                                PlaceholderText="Choose where repositories should be stored" />
                            <Button
                                Grid.Column="1"
                                MinWidth="116"
                                VerticalAlignment="Bottom"
                                Click="OnChooseDestinationClick">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon FontSize="16" Glyph="&#xED25;" />
                                    <TextBlock Text="Browse" />
                                </StackPanel>
                            </Button>
                        </Grid>

                        <CheckBox
                            x:Name="SubmodulesCheckBox"
                            Content="Initialize and fetch submodules recursively" />

                        <Border
                            Padding="14"
                            Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                            CornerRadius="8">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <FontIcon
                                    VerticalAlignment="Top"
                                    Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                    Glyph="&#xE946;" />
                                <TextBlock
                                    Grid.Column="1"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="The SSH probe is non-interactive and times out quickly. If it cannot confirm GitHub authentication, clone continues over HTTPS."
                                    TextWrapping="Wrap" />
                            </Grid>
                        </Border>

                        <Button
                            HorizontalAlignment="Left"
                            Click="OnCloneClick"
                            Style="{StaticResource AccentButtonStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon FontSize="16" Glyph="&#xE896;" />
                                <TextBlock Text="Clone repository" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
